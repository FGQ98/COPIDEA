# COPIDEA — Variables de entorno
# Copia este archivo como .env y rellena con tus valores de Firebase
# NUNCA subas .env a Git (ya esta en .gitignore)

VITE_FIREBASE_API_KEY=tu-api-key-aqui
VITE_FIREBASE_AUTH_DOMAIN=copidea-xxxxx.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=copidea-xxxxx
VITE_FIREBASE_STORAGE_BUCKET=copidea-xxxxx.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxxxxxx
